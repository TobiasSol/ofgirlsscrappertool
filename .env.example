# Pflicht: HikerAPI Token (Instagram Scraping)
HIKERAPI_TOKEN=dein_hikerapi_token_hier

# Pflicht: Passwort fuer den Login der Web-UI
APP_PASSWORD=dein_sicheres_passwort_hier

# Optional: aktiviert die KI-basierte DACH-Erkennung (Text + Vision via OpenAI)
OPENAI_API_KEY=sk-...

# Pflicht: Cloud-Postgres-URL (z.B. von Neon - https://neon.tech).
# Localhost UND Online-Deployment nutzen dieselbe DB.
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
